## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Visual Studio cache
.vs/

# Rider
.idea/

# VS Code
.vscode/

# Logs
*.log

# NuGet
*.nupkg
*.snupkg
packages/
!packages/build/

# NuGet Symbol Packages
*.symbols.nupkg

# NuGet Config
nuget.config

# OS files
.DS_Store
Thumbs.db

# Test results
TestResults/
*.trx
*.coverage

# Publish output
publish/
*.publishsettings

# Dotnet local tools
.dotnet/

# Resharper
_ReSharper*/
*.DotSettings.user

# Entity Framework migrations snapshots
*.dbmdl

# Temporary files
*.tmp
*.temp

# Generated files
Generated\ Files/

# Dotnet CLI
.dotnet-tools.json
